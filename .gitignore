# Godot
.godot/
.import/

# GDExtension ship folder — compiled addons in bin/ are tracked (see addons/WifiGD/WifiGD.gdextension)
# Linux x86_64 .so files should be built with ./build_linux_docker.sh (Ubuntu 20.04 / glibc 2.31)
# Ignore Windows/Godot temp locks when a DLL is in use
addons/WifiGD/bin/~*
demo/addons/WifiGD/bin/~*
addons/WifiGD/bin/*.TMP
demo/addons/WifiGD/bin/*.TMP

# SCons
.sconsign.dblite

# godot-cpp build artifacts
godot-cpp/bin/
godot-cpp/gen/
*.o
*.obj
*.lib
*.exp
*.pdb
*.ilk

# Export artifacts
export/
*.exe
*.pck
*.zip

# Test credentials (copy .env.example to .env at repo root)
.env

# IDE / OS
.vs/
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

