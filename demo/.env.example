# Copy this file to demo/.env and fill in a real network you can join for live connect tests.
# demo/.env is gitignored — never commit real credentials.
#
# Open networks: leave WIFI_PASSWORD empty.
WIFI_SSID=YourNetworkName
WIFI_PASSWORD=your-password-here

# Optional interface name (e.g. wlan0). Leave empty for the default Wi-Fi adapter.
WIFI_ADAPTER_ID=