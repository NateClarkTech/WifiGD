# Copy this file to .env at the repo root and fill in a real network for live connect tests.
# .env is gitignored — never commit real credentials.
#
# Open networks: leave WIFI_PASSWORD empty.
WIFI_SSID=YourNetworkName
WIFI_PASSWORD=your-password-here

# Optional adapter ID. Leave empty for the default Wi-Fi adapter.
#   Linux:   interface name (e.g. wlan0)
#   Windows: interface GUID (e.g. {xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx})
WIFI_ADAPTER_ID=